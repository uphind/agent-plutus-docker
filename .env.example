# ============================================================================
# Agent Plutus — Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#   nano .env                # edit values
#   docker compose up -d     # start
#
# ============================================================================


# ---------------------------------------------------------------------------
# 1. Domain
# ---------------------------------------------------------------------------
# The hostname where Agent Plutus will be accessible.
#
# TLS is automatic:
#   - Public domain → Caddy fetches a Let's Encrypt certificate
#   - "localhost"   → self-signed certificate (for testing)
#   - Corporate CA  → place cert.pem + key.pem in the certs/ folder
#
DOMAIN="ai-analytics.payoneer.com"


# ---------------------------------------------------------------------------
# 2. Secrets (MUST change before production)
# ---------------------------------------------------------------------------
# Generate each with:  openssl rand -base64 32
#
ENCRYPTION_KEY="change-me-to-a-32-char-secret!!"
AUTH_SECRET="change-me-auth-secret-32-chars!!"


# ---------------------------------------------------------------------------
# 3. Database password (optional — defaults to plutus_secret)
# ---------------------------------------------------------------------------
# POSTGRES_PASSWORD="a-strong-db-password"


# ---------------------------------------------------------------------------
# 4. SSO — Single Sign-On
# ---------------------------------------------------------------------------
# Choose your protocol: "oidc" or "saml"
SSO_PROVIDER="oidc"

# --- OIDC (Microsoft Entra ID, Okta, Google Workspace, Auth0, Keycloak) ---
# Register this redirect URI in your IdP:
#   https://{DOMAIN}/api/auth/callback/oidc
#
# For Microsoft Entra ID the issuer is:
#   https://login.microsoftonline.com/{tenant-id}/v2.0
#
SSO_ISSUER="https://login.microsoftonline.com/{tenant-id}/v2.0"
SSO_CLIENT_ID=""
SSO_CLIENT_SECRET=""

# --- SAML 2.0 (AD FS, Shibboleth, any SAML 2.0 IdP) ---
# Register this ACS URL in your IdP:
#   https://{DOMAIN}/api/auth/saml/acs
#
# SSO_SAML_ENTRY_POINT="https://adfs.company.com/adfs/ls/"
# SSO_SAML_ISSUER="https://ai-analytics.payoneer.com"
# SSO_SAML_CERT="base64-encoded-idp-signing-certificate"


# ---------------------------------------------------------------------------
# 5. SSO Domain Restriction
# ---------------------------------------------------------------------------
# Only allow users with these email domains to access the dashboard.
# Comma-separated. Anyone outside these domains gets a 403.
#
SSO_ALLOWED_DOMAINS="payoneer.com"


# ---------------------------------------------------------------------------
# 6. TLS Certificates (optional)
# ---------------------------------------------------------------------------
# For corporate CA certificates, place files in the certs/ directory:
#   certs/cert.pem   — your TLS certificate (or full chain)
#   certs/key.pem    — the private key
#
# The system auto-detects these files. No other config needed.
# If no files are present, Caddy uses Let's Encrypt (public) or
# self-signed (localhost) automatically.


# ---------------------------------------------------------------------------
# 7. Demo mode (testing only — NEVER enable in production)
# ---------------------------------------------------------------------------
# Bypasses SSO login entirely. For internal testing only.
# DEMO_MODE="true"
