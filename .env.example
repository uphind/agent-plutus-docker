# Copy this file to .env and adjust values as needed.
# For Docker deployment, these are set in docker-compose.yml — you don't need a .env file.

# Database connection (used at runtime; the Docker build uses a dummy value automatically)
DATABASE_URL="postgresql://tokenear:tokenear_secret@localhost:5432/tokenear?schema=public"

# 32-character secret for encrypting provider API keys at rest
ENCRYPTION_KEY="change-me-to-a-32-char-secret!!"

# Optional: NextAuth secret (for future auth features)
NEXTAUTH_SECRET="change-me-nextauth-secret"
